#version 450
/*
 * color_grading.comp Ã¢â‚¬â€ Unified color grading compute shader.
 *
 * Ã¢â‚¬â€œstyle single-pass color pipeline:
 * 1. Temperature / Tint (white balance)
 * 2. Exposure (photographic stops)
 * 3. Contrast (pivot around mid-gray)
 * 4. Highlights / Shadows (tonal range compression)
 * 5. Whites / Blacks (endpoint control)
 * 6. Saturation
 * 7. Faded Film / Vibrance / Creative Saturation
 * 8. Shadow color offsets (color wheels)
 * 9. Vignette
 *
 * All processing in linear float; sRGB conversion at boundaries.
 * Each section can be individually bypassed via enable flags.
 *
 * Push constant params[] layout matches ColorGrading::Param enum:
 * [0] Temperature (-100..100)
 * [1] Tint (-100..100)
 * [2] Exposure (-5..5 stops)
 * [3] Contrast (-100..100)
 * [4] Highlights (-100..100)
 * [5] Shadows (-100..100)
 * [6] Whites (-100..100)
 * [7] Blacks (-100..100)
 * [8] Saturation (0..200, 100=neutral)
 * [9] Faded Film (0..100)
 * [10] Sharpen (0..100) Ã¢â‚¬â€ not applied here (needs neighbor access)
 * [11] Vibrance (-100..100)
 * [12] Creative Sat (0..200, 100=neutral)
 * [13] Shadow R (-1..1)
 * [14] Shadow G (-1..1)
 * [15] Shadow B (-1..1)
 *
 * Note: params[16+] are in a second push if needed, but we keep
 * vignette params in a second set. For now we pack up to 16 in
 * the standard push block and handle vignette with 4 more params via
 * reuse of the standard 16-float block Ã¢â‚¬â€ we just read indices carefully.
 *
 * Actually, we have 20 params (0-19) + 4 enable flags (20-23) = 24 total.
 * The push constant block only holds 16 floats. So we extend it:
 * We rely on the EffectProcessor sending all params via push constants.
 * Since the total pushConstant is 80 bytes (16 ints header + 16 floats),
 * we can only send 16 floats. For ColorGrading we'll use the first 16
 * floats for the core params and encode vignette + enables differently.
 *
 * REVISED: We use params[0..15] = first 16 params. The vignette and
 * enable flags are packed into the remaining space:
 * params[0-8] = Basic Correction
 * params[9-12] = Creative 
 * params[13-15] = Color Wheels (shadow RGB)
 *
 * For vignette and enables, we pack them into the header padding:
 * Since we only have 16 floats, we put vignette params into
 * params[9-12] range and creative into params[13-15]... 
 *
 * FINAL LAYOUT (fits in 16 floats):
 * [0] Temperature
 * [1] Tint
 * [2] Exposure
 * [3] Contrast
 * [4] Highlights
 * [5] Shadows
 * [6] Whites
 * [7] Blacks
 * [8] Saturation (0-200, /100 for multiplier)
 * [9] Faded Film (0-100, /100)
 * [10] Vibrance (-100..100, /100)
 * [11] Creative Sat (0-200, /100)
 * [12] Vignette Amount (-5..5)
 * [13] Vignette Midpoint (0-100, /100)
 * [14] Vignette Roundness (0-100, /100)
 * [15] Vignette Feather (0-100, /100)
 */

layout(local_size_x = 16, local_size_y = 16) in;

layout(binding = 0, rgba8) uniform writeonly image2D outputImage;
layout(binding = 1) uniform sampler2D inputImage;

layout(push_constant) uniform PushConstants {
 int width;
 int height;
 int paramCount;
 int _pad;
 float params[28];
} pc;

// Ã¢â€â‚¬Ã¢â€â‚¬ sRGB <-> Linear Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬

vec3 srgbToLinear(vec3 c) {
 return mix(c / 12.92, pow((c + 0.055) / 1.055, vec3(2.4)), step(0.04045, c));
}

vec3 linearToSrgb(vec3 c) {
 return mix(c * 12.92, 1.055 * pow(max(c, vec3(0.0)), vec3(1.0/2.4)) - 0.055, step(0.0031308, c));
}

// Ã¢â€â‚¬Ã¢â€â‚¬ RGB <-> HSL (for vibrance) Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬

vec3 rgbToHsl(vec3 c) {
 float mx = max(c.r, max(c.g, c.b));
 float mn = min(c.r, min(c.g, c.b));
 float l = (mx + mn) * 0.5;
 if (mx == mn) return vec3(0.0, 0.0, l);
 float d = mx - mn;
 float s = l > 0.5 ? d / (2.0 - mx - mn) : d / (mx + mn);
 float h;
 if (mx == c.r) h = (c.g - c.b) / d + (c.g < c.b ? 6.0 : 0.0);
 else if (mx == c.g) h = (c.b - c.r) / d + 2.0;
 else h = (c.r - c.g) / d + 4.0;
 return vec3(h / 6.0, s, l);
}

float hue2rgb(float p, float q, float t) {
 if (t < 0.0) t += 1.0;
 if (t > 1.0) t -= 1.0;
 if (t < 1.0/6.0) return p + (q - p) * 6.0 * t;
 if (t < 0.5) return q;
 if (t < 2.0/3.0) return p + (q - p) * (2.0/3.0 - t) * 6.0;
 return p;
}

vec3 hslToRgb(vec3 hsl) {
 if (hsl.y == 0.0) return vec3(hsl.z);
 float q = hsl.z < 0.5 ? hsl.z * (1.0 + hsl.y) : hsl.z + hsl.y - hsl.z * hsl.y;
 float p = 2.0 * hsl.z - q;
 return vec3(
 hue2rgb(p, q, hsl.x + 1.0/3.0),
 hue2rgb(p, q, hsl.x),
 hue2rgb(p, q, hsl.x - 1.0/3.0)
 );
}

// Ã¢â€â‚¬Ã¢â€â‚¬ Smooth tonal range functions Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬

// Soft highlight compression: affects bright tones only
float highlightCurve(float luma) {
 return smoothstep(0.5, 1.0, luma);
}

// Soft shadow lift: affects dark tones only
float shadowCurve(float luma) {
 return 1.0 - smoothstep(0.0, 0.5, luma);
}

void main()
{
 ivec2 pixel = ivec2(gl_GlobalInvocationID.xy);
 if (pixel.x >= pc.width || pixel.y >= pc.height) return;

 vec2 uv = (vec2(pixel) + 0.5) / vec2(pc.width, pc.height);
 vec4 color = texture(inputImage, uv);

 // Unpack parameters
 float temperature = pc.params[0]; // -100..100
 float tint = pc.params[1]; // -100..100
 float exposure = pc.params[2]; // -5..5 stops
 float contrast = pc.params[3]; // -100..100
 float highlights = pc.params[4]; // -100..100
 float shadows = pc.params[5]; // -100..100
 float whites = pc.params[6]; // -100..100
 float blacks = pc.params[7]; // -100..100
 float saturation = pc.params[8]; // 0..200 (100 neutral)
 float fadedFilm = pc.params[9]; // 0..100
 float vibrance = pc.params[10]; // -100..100
 float creativeSat = pc.params[11]; // 0..200 (100 neutral)
 float vigAmount = pc.params[12]; // -5..5
 float vigMidpoint = pc.params[13]; // 0..100
 float vigRoundness = pc.params[14]; // 0..100
 float vigFeather = pc.params[15]; // 0..100

 // Convert to linear for processing
 vec3 c = srgbToLinear(color.rgb);

 // Ã¢â€â‚¬Ã¢â€â‚¬ 1. White Balance (Temperature + Tint) Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
 // Temperature shifts blue-orange axis; Tint shifts green-magenta
 float tempNorm = temperature / 100.0;
 float tintNorm = tint / 100.0;
 c.r += tempNorm * 0.08;
 c.b -= tempNorm * 0.08;
 c.g += tintNorm * 0.05;

 // Ã¢â€â‚¬Ã¢â€â‚¬ 2. Exposure (photographic stops) Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
 if (abs(exposure) > 0.001) {
 c *= pow(2.0, exposure);
 }

 // Ã¢â€â‚¬Ã¢â€â‚¬ 3. Contrast (pivot around 0.18 mid-gray in linear) Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
 if (abs(contrast) > 0.1) {
 float contrastMul = 1.0 + contrast / 100.0;
 float pivot = 0.18; // mid-gray in linear
 c = (c - pivot) * contrastMul + pivot;
 }

 // Ã¢â€â‚¬Ã¢â€â‚¬ 4. Highlights / Shadows (soft tonal remapping) Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
 {
 float luma = dot(c, vec3(0.2126, 0.7152, 0.0722));

 // Highlights: compress or expand bright tones
 if (abs(highlights) > 0.1) {
 float hMask = highlightCurve(luma);
 float hShift = highlights / 100.0 * 0.5;
 c += hShift * hMask;
 }

 // Shadows: lift or crush dark tones
 if (abs(shadows) > 0.1) {
 float sMask = shadowCurve(luma);
 float sShift = shadows / 100.0 * 0.5;
 c += sShift * sMask;
 }
 }

 // Ã¢â€â‚¬Ã¢â€â‚¬ 5. Whites / Blacks (endpoint control) Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
 if (abs(whites) > 0.1) {
 float wShift = whites / 100.0 * 0.3;
 c = mix(c, max(c, vec3(0.0)) + wShift, smoothstep(0.6, 1.0, c));
 }
 if (abs(blacks) > 0.1) {
 float bShift = blacks / 100.0 * 0.3;
 c = mix(c, c + bShift, smoothstep(0.4, 0.0, c));
 }

 // Ã¢â€â‚¬Ã¢â€â‚¬ 6. Saturation (basic) Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
 {
 float satMul = saturation / 100.0;
 float luma = dot(c, vec3(0.2126, 0.7152, 0.0722));
 c = mix(vec3(luma), c, satMul);
 }

 // Ã¢â€â‚¬Ã¢â€â‚¬ 7. Creative section Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬

 // Faded Film (lift blacks, compress blacks toward gray)
 if (fadedFilm > 0.1) {
 float fade = fadedFilm / 100.0;
 float liftAmount = fade * 0.15; // Max lift ~15% of black point
 c = c + liftAmount * (1.0 - c); // Soft lift that preserves highlights
 // Also reduce contrast slightly
 float pivot = 0.5;
 c = mix(c, vec3(pivot), fade * 0.15);
 }

 // Vibrance (saturate desaturated colors more, protect skin tones)
 if (abs(vibrance) > 0.1) {
 float vibNorm = vibrance / 100.0;
 vec3 hsl = rgbToHsl(clamp(c, 0.0, 1.0));
 // Lower-saturation pixels get more boost
 float boostFactor = 1.0 - hsl.y; // inverse of current sat
 // Protect skin tones (hue ~30Ã‚Â° = 30/360 Ã¢â€°Ë† 0.083)
 float skinProximity = 1.0 - smoothstep(0.0, 0.12, abs(hsl.x - 0.083));
 float protection = mix(1.0, 0.5, skinProximity);
 float adjustment = vibNorm * boostFactor * protection;
 hsl.y = clamp(hsl.y + adjustment * 0.5, 0.0, 1.0);
 c = hslToRgb(hsl);
 }

 // Creative Saturation (on top of basic)
 {
 float cSatMul = creativeSat / 100.0;
 if (abs(cSatMul - 1.0) > 0.001) {
 float luma = dot(c, vec3(0.2126, 0.7152, 0.0722));
 c = mix(vec3(luma), c, cSatMul);
 }
 }

 // Ã¢â€â‚¬Ã¢â€â‚¬ 8. Color Wheels (Lift/Gamma/Gain per tonal range) Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
 {
 // Shadow (Lift) Ã¢â‚¬â€ affects dark tones
 vec3 shadowOff = vec3(pc.params[16], pc.params[17], pc.params[18]);
 float shadowMaster = pc.params[25];
 // Midtone (Gamma) Ã¢â‚¬â€ affects mid tones
 vec3 midtoneOff = vec3(pc.params[19], pc.params[20], pc.params[21]);
 float midtoneMaster = pc.params[26];
 // Highlight (Gain) Ã¢â‚¬â€ affects bright tones
 vec3 highlightOff = vec3(pc.params[22], pc.params[23], pc.params[24]);
 float highlightMaster = pc.params[27];

 float luma = dot(c, vec3(0.2126, 0.7152, 0.0722));

 // Tonal range masks using smooth transitions
 float shadowMask = 1.0 - smoothstep(0.0, 0.5, luma);
 float highlightMask = smoothstep(0.5, 1.0, luma);
 float midtoneMask = 1.0 - shadowMask - highlightMask;

 // Apply per-range color offsets + master luminance
 vec3 shadowShift = (shadowOff + vec3(shadowMaster)) * shadowMask * 0.3;
 vec3 midtoneShift = (midtoneOff + vec3(midtoneMaster)) * midtoneMask * 0.3;
 vec3 highlightShift = (highlightOff + vec3(highlightMaster)) * highlightMask * 0.3;

 c += shadowShift + midtoneShift + highlightShift;
 }

 // Ã¢â€â‚¬Ã¢â€â‚¬ 9. Vignette Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
 if (abs(vigAmount) > 0.01) {
 float aspect = float(pc.width) / float(pc.height);
 vec2 centered = uv - 0.5;
 centered.x *= aspect;

 float midpoint = vigMidpoint / 100.0;
 float roundness = vigRoundness / 100.0;
 float feather = max(vigFeather / 100.0, 0.01);

 // Distance from center
 float dist;
 if (roundness > 0.99) {
 dist = length(centered);
 } else {
 float rectDist = max(abs(centered.x), abs(centered.y));
 float circDist = length(centered);
 dist = mix(rectDist, circDist, roundness);
 }

 // Vignette falloff
 float radius = midpoint * 1.4; // scale midpoint to useful range
 float vig = smoothstep(radius - feather * 0.5, radius + feather * 0.5, dist);
 vig *= vigAmount;

 // Darken or lighten
 c *= 1.0 - vig;
 }

 // Ã¢â€â‚¬Ã¢â€â‚¬ Output Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
 // Convert back to sRGB
 c = linearToSrgb(clamp(c, 0.0, 1.0));

 imageStore(outputImage, pixel, vec4(c, color.a));
}
